# =============================================================================
# Binance Thailand — environment template
# Copy to ".env" in the project root and edit values. Never commit ".env".
#
# REAL ORDERS require ALL of the following:
#   1) LIVE_TRADING=true  (below) — enforced in config.py; without it, live
#      YAML alone will not arm the exchange order path safely.
#   2) bot_config.yaml: simulate_only: false and read_only: false
#   3) Do NOT set BOT_STARTUP_TEST_MODE (it forces dry_run + read_only)
#   4) SIMULATE_ONLY unset or false; BOT_READ_ONLY unset or false
# =============================================================================

# --- Binance Thailand API (required) ---
BINANCE_API_KEY=replace_with_real_binance_api_key
BINANCE_API_SECRET=replace_with_real_binance_api_secret
BINANCE_BASE_URL=https://api.binance.th
DEFAULT_SYMBOL=BTCUSDT

# --- Order / trading mode (config.py) ---
DEFAULT_ORDER_TYPE=limit
MIN_ORDER_AMOUNT=100

# false = never arm real orders (config.py). true = allow real orders when YAML
# is also live (simulate_only/read_only false, no BOT_STARTUP_TEST_MODE).
LIVE_TRADING=true

LOG_LEVEL=INFO

# --- Extra safety rails (optional) ---
# Force read-only executor even if YAML allows trading:
BOT_READ_ONLY=false
# If set to true/1/yes, main.py treats the bot as simulate-only:
# SIMULATE_ONLY=
# BOT_MODE=
# TRADING_PAIR=

BOT_CONFIG_PATH=bot_config.yaml

# --- Telegram (optional) ---
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Storage / services ---
PORT=8000
SQLITE_DB_PATH=crypto_bot.db
